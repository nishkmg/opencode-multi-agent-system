{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "context-mode",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./plugins/agent-memory-system.ts"
  ],
  "default_agent": "coordinator",
  "agent": {
    "coordinator": {
      "description": "Primary agent - coordinates tasks, delegates to subagents as needed",
      "model": "anthropic-billing/claude-sonnet-4-6",
      "invoke": ["advisor", "builder", "reviewer"]
    },
    "advisor": {
      "description": "Architecture & reasoning - deeply analyze requirements",
      "model": "anthropic-billing/claude-opus-4-6",
      "mode": "subagent"
    },
    "builder": {
      "description": "Execution agent - implement features",
      "model": "anthropic-billing/claude-sonnet-4-6",
      "mode": "subagent"
    },
    "reviewer": {
      "description": "Code reviewer - validate quality",
      "model": "anthropic-billing/claude-haiku-4-5",
      "mode": "subagent"
    }
  },
  "delegation": {
    "default_invoke": ["advisor", "builder", "reviewer"]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}